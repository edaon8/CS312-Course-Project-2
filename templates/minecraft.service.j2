[Unit]
Description=Minecraft Dedicated Server (Acme Corp Custom)
After=network.target network-online.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/minecraft
Type=forking

# Create a detached tmux session running the game engine
ExecStart=/usr/bin/tmux new-session -s minecraft -d '/usr/bin/java -Xmx2G -Xms2G -jar server.jar nogui'

# FIX: Send a /stop command through tmux to save world states gracefully before exiting
ExecStop=/usr/bin/tmux send-keys -t minecraft "stop" Enter
# Wait up to 30 seconds for the world files to write to storage cleanly
TimeoutStopSec=30

Restart=always

[Install]
WantedBy=multi-user.target